# =============================================================================
# Codecarto .gitignore
# =============================================================================

# Secrets & tokens
token.txt
secrets.txt
.env
.env.*

# =============================================================================
# Python
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
MANIFEST

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.nox/
.tox/
*.pstats

# Type checking
.mypy_cache/
.pytype/

# =============================================================================
# JavaScript / Node
# =============================================================================
node_modules/
.vite/
web/dist/

# =============================================================================
# IDE / Editor
# =============================================================================
.vscode/
.idea/
.vs/
*.swp
*.swo
.DS_Store

# =============================================================================
# Documentation
# =============================================================================
site/
docs/_build/
docs/build/

# =============================================================================
# Project specific
# =============================================================================
output/
.dev/
playground/
sandbox/

# Jupyter
.ipynb_checkpoints/

# Docker
docker.sh
dev.sh

# Screenshots cache (mkdocs)
.cache/
.screenshot_cache/
